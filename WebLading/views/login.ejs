<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WebLading - Đăng nhập</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="container">
      <nav class="nav-landing">
        <a href="/#intro" class="nav-link" id="nav-intro">Cốt Truyện Huyền Thoại</a>
        <a href="/download" class="nav-link" id="nav-download">Tải Game Ngay</a>
        <a href="/login" class="nav-link" id="nav-login">Đăng nhập</a>
      </nav>
      
      <div class="card" style="margin-top: 40px;">
        <div class="header">
          <div class="brand">WebLading</div>
          <div class="subtitle">Đăng nhập để xem dữ liệu nhân vật (read-only)</div>
        </div>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <form method="POST" action="/login" class="form">
          <label class="label">
            Username
            <input name="username" class="input" placeholder="demo" autocomplete="username" required />
          </label>

          <label class="label">
            Password
            <input
              name="password"
              type="password"
              class="input"
              placeholder="demo123"
              autocomplete="current-password"
              required
            />
          </label>

          <button type="submit" class="button">Đăng nhập</button>

          <div class="hint">
            <% if (mongoEnabled) { %>
              Đang dùng MongoDB (dữ liệu thật từ game).
            <% } else { %>
              Tài khoản mẫu: <span class="mono">demo / demo123</span>
            <% } %>
          </div>
        </form>
      </div>
      
      <footer class="footer" style="justify-content: center; opacity: 0.4; margin-top: 100px; padding-bottom: 40px;">
        <p>&copy; 2026 Tetra: The Shattered Realm. Too powerful for mortal hardware.</p>
      </footer>
    </div>
  </body>
</html>

