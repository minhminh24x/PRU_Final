  m_Name: NPC_Sena
  m_EditorClassIdentifier: Assembly-CSharp::NPCData
  npcName: Sena
  portrait: {fileID: -855298285791758126, guid: e3ecce776fc453f449d10be0aa3733aa, type: 3}
  portraitController: {fileID: 9100000, guid: b5f96721560f7be44a4b412c985f8fa2, type: 2}
  dialogueLines:
  - "Ch\xE0o hi\u1EC7p s\u0129, nh\xECn c\u1EADu c\xF3 v\u1EBB m\u1EC7t m\u1ECFi
    \u0111\u1EA5y."
  - "Ta l\xE0 Sena, m\u1ED9t th\u01B0\u01A1ng nh\xE2n lang thang t\xECnh c\u1EDD
    d\u1EEBng ch\xE2n \u1EDF ng\xF4i l\xE0ng n\xE0y."
  - "D\u1EA1o n\xE0y qu\xE1i v\u1EADt ho\xE0nh h\xE0nh, ta \u0111ang k\u1EB9t l\u1EA1i
    \u0111\xE2y. N\u1EBFu c\u1EADu c\u1EA7n \u0111\u1ED3 ti\u1EBFp t\u1EBF th\xEC
    ta c\xF3 th\u1EC3 b\xE1n l\u1EA1i v\u1EDBi gi\xE1 r\u1EBB cho."
  repeatDialogueLines:
  - "L\u1EA1i l\xE0 c\u1EADu \xE0? Gi\u1EEF m\u1EA1ng cho k\u1EF9 nh\xE9."
  rewardItem: {fileID: 11400000, guid: c2853d4acd78c724f9bb791abb1a4739, type: 2}
  rewardAmount: 1
  rewardManaDirect: 0
